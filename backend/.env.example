# ─── APPLICATION ───────────────────────────────────────────
APP_NAME=RAGBot System
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=cambia_esto_por_una_clave_muy_segura_de_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── DATABASE ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ragbot_user:password@localhost:5432/ragbot_db
DATABASE_URL_SYNC=postgresql://ragbot_user:password@localhost:5432/ragbot_db

# ─── REDIS (cache de sesiones y rate limiting) ─────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI PROVIDERS ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
OLLAMA_BASE_URL=http://localhost:11434

# ─── EMBEDDINGS ────────────────────────────────────────────
# Opciones: openai | sentence_transformers | google
DEFAULT_EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ─── RAG SETTINGS ──────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
MAX_CONTEXT_TOKENS=4000

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://tudominio.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# ─── FILE STORAGE ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── LOGGING ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/ragbot.log
